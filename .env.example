# === API Keys (Required) ===
OPENROUTER_API_KEY=sk-or-your-key-here
TAVILY_API_KEY=tvly-your-key-here
SERPER_API_KEY=your-serper-key-here
NEWSAPI_KEY=your-newsapi-key-here
LANGSMITH_API_KEY=your-langsmith-key-here

# === Hierarchical LLM Routing (via OpenRouter) ===
LLM_MODEL_CHEAP=google/gemini-2.0-flash-exp:free
LLM_MODEL_MID=anthropic/claude-3.5-haiku
LLM_MODEL_PREMIUM=anthropic/claude-3.5-sonnet

# === Embeddings ===
EMBEDDING_MODEL=text-embedding-3-small

# === Cache (Optional — defaults to localhost) ===
REDIS_URL=redis://localhost:6379

# === LangSmith Observability ===
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=deep-research-agent-v2

# Environment Flag for Render
RENDER=true
PRODUCTION=true

# Memory optimization settings
PYTHONUNBUFFERED=1
PYTHONHASHSEED=0
